{
  "name": "runwars",
  "version": "1.0.0",
  "private": true,
  "description": "RunWars — Real-time territory-based running game",
  "workspaces": [
    "apps/mobile",
    "packages/shared",
    "apps/backend"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "backend": "npm run dev --workspace=@runwars/backend",
    "dev": "concurrently \"npm run backend\" \"npm run mobile\"",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:backend": "npm run build --workspace=@runwars/backend",
    "start:backend": "npm run start --workspace=@runwars/backend",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
