# PostgreSQL connection string (with PostGIS)
DATABASE_URL=postgresql://user:password@localhost:5432/runwars

# Redis connection
REDIS_URL=redis://localhost:6379

# Firebase Admin SDK (download from Firebase Console → Service Accounts)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Server
PORT=3000
NODE_ENV=development

# CORS — your Expo dev client URL or wildcard for dev
CORS_ORIGIN=*
